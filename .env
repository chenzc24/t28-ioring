# ──────────────────────────────────────────────────────────────────────────
# T28 IO Ring Skill Configuration
#
# This file is loaded automatically by the skill's bridge_utils.py.
# It is independent from the project-root .env (bridge config).
#
# Fields you may need to change are marked with:  # ← CHANGE if needed
# ──────────────────────────────────────────────────────────────────────────

# ── Calibre DRC/LVS ─────────────────────────────────────────────────────
# Absolute path to your T28 cds.lib on the EDA server (Linux path).
# This tells Calibre where to find the TSMC28 PDK libraries.
# ← CHANGE path to match your cds.lib location
CDS_LIB_PATH_28=/home/chenzc_intern25/TSMC28/llm_IO/cds.lib

# ── Filesystem Mode ─────────────────────────────────────────────────────
# "remote" = Windows PC connecting to Linux (no shared filesystem) — default.
# "shared"  = both machines see the same paths via NFS (Linux-to-Linux only).
# Leave unset to auto-detect.
VB_FS_MODE=remote

# ── Draft Editor (Step 2b) ──────────────────────────────────────────────
# "on"  = Open the Draft Editor automatically after Step 2, before enrichment.
#         Users can visually place/arrange pads, set device types, and confirm
#         the structural layout. The draft output then feeds Step 3 enrichment.
# "off" = Skip the Draft Editor. Step 2 text-based draft goes directly to Step 3.
#         (User can still request the editor by saying "I want to use the editor"
#          or similar — the .env setting is a default, not a hard gate.)
# Default: off
AMS_DRAFT_EDITOR=off

# ── Layout Editor / Confirmation Editor (Step 6) ────────────────────────
# "on"  = Ask user whether to open browser-based Confirmation Editor at Step 6.
#         Full layout with fillers, pin connections, and corners is shown.
# "off" = Skip editor automatically (recommended for unattended/batch runs).
# Default: off
AMS_LAYOUT_EDITOR=on

# ── Output Paths (optional) ─────────────────────────────────────────────
# Resolution order: AMS_OUTPUT_ROOT > AMS_IO_AGENT_PATH/output > ./output
AMS_OUTPUT_ROOT=C:\Users\90590\Desktop\bridge-Agent\output
# AMS_IO_AGENT_PATH=
