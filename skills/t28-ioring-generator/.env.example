# T28 IO ring generator configuration.
# Copy to .env or .env.local and fill in site-specific values.

# Remote Linux path to the T28 cds.lib used by Virtuoso/Calibre.
CDS_LIB_PATH_28=/path/to/TSMC28/cds.lib

# Filesystem mode for Calibre transfer:
#   remote = Windows/local machine connects to EDA server over SSH
#   shared = local and EDA server share the same filesystem path
VB_FS_MODE=remote

# Editor defaults. Users can still override by explicitly asking for editors.
AMS_DRAFT_EDITOR=off
AMS_LAYOUT_EDITOR=off

# Shared output root used by both t28-ioring-generator and t28-ioring-simulator.
# If unset, scripts fall back to a local output directory.
AMS_OUTPUT_ROOT=/path/to/project/output
