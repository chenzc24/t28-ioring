#!/bin/csh
# Site-local overrides for Calibre/PDK paths.
#
# Copy this file to site_local.csh and edit with your site's values:
#   cp site_local.csh.example site_local.csh
#
# This file is sourced by env_common.csh BEFORE the default paths are set,
# so any variables you define here take precedence over the built-in defaults.
#
# You can also set these in your shell environment or site cshrc;
# env_common.csh checks $?VAR_NAME and skips the default if already set.

# ── Calibre installation ──────────────────────────────────────────────────
# Uncomment and set to your Calibre install root:
# setenv MGC_HOME /your/site/calibre/install/path

# ── Cadence environment setup ─────────────────────────────────────────────
# If your site provides Cadence/Mentor setup scripts, source them here.
# These are called BEFORE the Calibre csh scripts run, so that tools
# like strmout, si, and calibre are on PATH and licenses are configured.
#
# Example:
# source /your/site/cshrc/.cshrc.cadence
# source /your/site/cshrc/.cshrc.mentor

# ── T28 PDK paths ────────────────────────────────────────────────────────
# Uncomment and set to your site's PDK paths:
# setenv PDK_LAYERMAP_28 /your/site/tsmc28n/tsmcN28.layermap
# setenv incFILE_28 /your/site/tsmc28n/Calibre/lvs/source.added

# ── T180 PDK paths (if using T180) ───────────────────────────────────────
# setenv PDK_LAYERMAP_180 /your/site/tsmc180/tsmc18.layermap
# setenv incFILE_180 /your/site/tsmc180/calibre_rule/lvs/source.added

# ── cds.lib path ──────────────────────────────────────────────────────────
# Alternatively, set CDS_LIB_PATH here if you prefer csh-level config:
# setenv CDS_LIB_PATH_28 /your/site/T28/cds.lib
