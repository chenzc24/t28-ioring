# T28 IO ring simulator configuration.
# Copy to .env or .env.local and fill in site-specific values.

# Git Bash path conversion guards for Windows hosts running native Python.
MSYS_NO_PATHCONV=1
MSYS2_ARG_CONV_EXCL=*

# Recommended on Windows/OpenSSH jump-host setups; avoids stale mux socket upload failures.
VB_DISABLE_CONTROL_MASTER=1

# Remote Linux path to cds.lib. If omitted, simulator code falls back to CDS_LIB_PATH_28.
SIM_CDS_LIB=/path/to/TSMC28/cds.lib

# Remote Cadence IC and Spectre/MMSIM installation roots.
SIM_IC_ROOT=/path/to/cadence/IC618
SIM_MMSIM_ROOT=/path/to/cadence/SPECTRE

# Optional license variables. Leave blank to let the flow discover them from Virtuoso.
SIM_LM_LICENSE_FILE=
SIM_CDS_LIC_FILE=

# TSMC28 IO pad SPICE model include.
SIM_PDK_IO_SPECTRE_INCLUDE=/path/to/tphn28hpcpgv18.spi

# TSMC28 core Spectre model include and TT sections.
SIM_PDK_CORE_SPECTRE_INCLUDE=/path/to/crn28ull_model.scs
SIM_PDK_CORE_SPECTRE_SECTIONS=pre_simu,ttmacro_mos_moscap,tt_res_bip_dio_disres,tt_mom,tt_ind_jvar,tt_r_metal,noise_worst

# Shared output root used by both t28-ioring-generator and t28-ioring-simulator.
# Simulator runs are created under ${AMS_OUTPUT_ROOT}/simulation/<timestamp>.
AMS_OUTPUT_ROOT=/path/to/project/output
